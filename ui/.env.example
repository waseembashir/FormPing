# ─────────────────────────────────────────────────────────────────────────
# FormPing UI — environment variables
#
# Copy to `.env.local` for local development, or set these in the Railway
# service "Variables" tab for production. `.env.local` is gitignored — never
# commit real secrets.
#
# AUTH IS OPTIONAL: if NONE of the auth vars are set, the app runs with an OPEN
# gate (no login required) — handy for local dev. The gate turns ON automatically
# as soon as Google auth (or the legacy password auth) is configured.
# ─────────────────────────────────────────────────────────────────────────

# ── Storage: Supabase (Postgres) ─────────────────────────────────────────
# When BOTH are set, FormPing stores everything in Supabase. When unset, it
# falls back to JSON files on disk — so the app runs either way.
#
# Get these from your Supabase project → Settings → API Keys:
#   SUPABASE_URL              → "Project URL" (https://<ref>.supabase.co)
#   SUPABASE_SERVICE_ROLE_KEY → a SECRET key (sb_secret_… / service_role JWT)
#
# The secret key bypasses Row Level Security, so it is SERVER-ONLY: it has no
# NEXT_PUBLIC_ prefix and must never be committed or exposed to the browser.
# Run the migrations in supabase/migrations/ before first use.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Which Postgres SCHEMA to use. Optional — defaults to `public`.
#
# Prod and development share one Supabase project but are isolated by schema, so
# they never share a table (working agreement rule 6, "Production data is sacred"):
#
#   public → PRODUCTION   — Railway leaves this UNSET
#   dev    → development  — set SUPABASE_SCHEMA=dev in your local .env.local
#
# Keep this set to `dev` locally: our test/smoke scripts insert and delete rows,
# and this is what stops them ever reaching a live client's data.
# SUPABASE_SCHEMA=dev

# ── Slack notifications (optional, free) ─────────────────────────────────
# Set this to a Slack Incoming Webhook to get a message in your channel when
# a monitor detects a change or a failure — Change Monitor (watch + one-off
# compare runs), Form Watch, and Site Watch all use this same webhook.
# Create one at: https://api.slack.com/messaging/webhooks
# Leave empty to disable: runs still execute and are stored, the Slack send is
# simply skipped (best-effort — a Slack outage never breaks a run).
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── Google OAuth (primary sign-in) ───────────────────────────────────────
# Create an OAuth 2.0 "Web application" client at:
#   https://console.cloud.google.com/apis/credentials
# Add this Authorized redirect URI to that client:
#   https://YOUR-DOMAIN/api/auth/google/callback
#   http://localhost:3000/api/auth/google/callback   (for local testing)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. The exact callback URL registered above. If omitted, it is derived
# from the incoming request origin (honors x-forwarded-* behind Railway's
# proxy). Set it explicitly in production if you hit redirect-URI mismatches.
# GOOGLE_REDIRECT_URI=https://YOUR-DOMAIN/api/auth/google/callback

# Comma-separated list of email domains allowed to sign in. Defaults to
# "apexure.com" if unset. Anyone outside these domains is rejected after Google
# verifies them. Add client domains here without touching code.
ALLOWED_AUTH_DOMAINS=apexure.com

# REQUIRED when using Google auth: a long random string used to sign the
# session cookie (there is no password to derive it from in Google-only mode).
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SESSION_SECRET=

# Optional. Session lifetime in days (default 7).
# AUTH_SESSION_DAYS=7

# ── Legacy username/password auth (optional, kept for backward compat) ────
# Not needed when using Google auth. If set, the password gate also activates.
# AUTH_USER=
# AUTH_PASSWORD=
